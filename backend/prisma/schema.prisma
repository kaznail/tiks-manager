generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id             String    @id @default(uuid())
  adminCodeHash  String    // Hashed code (e.g., 20192019)
  createdAt      DateTime  @default(now())
}

model Employee {
  id             String    @id @default(uuid())
  username       String    @unique
  password       String    // Hashed password
  
  // Advanced CV Details
  name           String    // Preferred short name or title
  fullName       String?   // Full triple name
  age            Int?
  education      String?   // Current studies / degree
  province       String?   // Governorate / City
  gender         String?   // Male / Female
  masterCard     String?   // Financial tracking
  platform       String?   // Platform e.g. TikTok, Instagram
  allowedLeaves  Int       @default(21) // Allowed yearly leaves
  currentBalance Float     @default(0)  // Virtual Wallet Balance
  
  // Base Details
  salary         Float?    // Expected salary rate
  monthlyVideoTarget Int?  // Monthly video target set by admin
  startDate      DateTime  @default(now())
  fcmToken       String?   // Firebase Cloud Messaging Token
  
  // Uploaded Photos Paths
  photo1         String?
  photo2         String?
  photo3         String?
  
  role           String    @default("employee")
  isBlocked      Boolean   @default(false)     // Blacklist: temporarily block employee
  blockedReason  String?                        // Reason for blocking
  blockedAt      DateTime?                      // When the employee was blocked
  
  // Relations
  reports           Report[]
  warnings          Warning[]
  rewards           Reward[]
  receivedNotes     Note[]
  notifications     Notification[]
  accountLinks      AccountLink[]
  salaryRecords     SalaryRecord[]
  warningRequests   WarningRequest[]
  attendance        AttendanceRecord[]
  chatMessages      ChatMessage[]
  performanceReviews PerformanceReview[]
  contracts         Contract[]
  monthlyTargets    MonthlyTarget[]
  leaveRequests     LeaveRequest[]
  salaryChangeLogs  SalaryChangeLog[]
  financialRequests FinancialRequest[]
}

model AccountLink {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  url             String
  platform        String?
  createdAt       DateTime       @default(now())
}

model SalaryRecord {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  amount          Float
  notes           String?
  paidAt          DateTime       @default(now())
}

model Report {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  tiktokUrl       String         @unique
  submittedAt     DateTime       @default(now())
  status          String         @default("ON_TIME")
  dateString      String
  adminNotes      String?
}

model Warning {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  type            String
  reason          String?
  issuedAt        DateTime       @default(now())
}

model Reward {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  reason          String
  issuedAt        DateTime       @default(now())
}

model Note {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  content         String
  createdAt       DateTime       @default(now())
}

model Notification {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  message         String
  isRead          Boolean        @default(false)
  isAdminOnly     Boolean        @default(false) // true = only admin can see, false = employee notification
  createdAt       DateTime       @default(now())
}

// === NEW MODELS ===

// Smart Warning System — Admin must approve before warning is issued
model WarningRequest {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  type            String         // e.g. "تأخر", "غياب", "عدم إرسال تقرير"
  reason          String
  status          String         @default("PENDING") // PENDING, APPROVED, REJECTED
  autoGenerated   Boolean        @default(false)      // Was it auto-generated by the system?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
}

// Attendance — Smart: linked to video submissions
model AttendanceRecord {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  date            String         // YYYY-MM-DD format
  status          String         @default("PRESENT") // PRESENT, ABSENT, LATE
  videoLinks      String?        // JSON array of video URLs submitted that day
  videoCount      Int            @default(0)
  checkInTime     DateTime       @default(now())
  notes           String?

  @@unique([employeeId, date])
}

// Internal Chat — between Admin and Employee
model ChatMessage {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  content         String
  isFromAdmin     Boolean        @default(false) // true = admin sent, false = employee sent
  isRead          Boolean        @default(false)
  createdAt       DateTime       @default(now())
}

// Activity Log — Tracks all admin actions
model ActivityLog {
  id              String         @id @default(uuid())
  action          String         // e.g. "حذف موظف", "إرسال راتب", "إصدار تحذير"
  details         String?        // JSON or plain text details
  performedBy     String         @default("admin")
  createdAt       DateTime       @default(now())
}

// Performance Review
model PerformanceReview {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  month           String         // e.g. "2026-04"
  rating          Int            // 1–5 stars
  notes           String?
  createdAt       DateTime       @default(now())

  @@unique([employeeId, month])
}

// Employee Contracts (file uploads)
model Contract {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  title           String
  filePath        String         // Path to the uploaded contract file
  createdAt       DateTime       @default(now())
}

// Calendar Events
model CalendarEvent {
  id              String         @id @default(uuid())
  title           String
  description     String?
  date            String         // YYYY-MM-DD
  type            String         @default("عام") // راتب, إجازة, مناسبة, عام
  createdAt       DateTime       @default(now())
}

// System Settings
model SystemSettings {
  id              String         @id @default(uuid())
  key             String         @unique
  value           String
  updatedAt       DateTime       @updatedAt
}

// Monthly Video Targets
model MonthlyTarget {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  month           String         // e.g. "2026-04"
  targetCount     Int            // Target number of videos
  achievedCount   Int            @default(0) // Actual videos submitted
  createdAt       DateTime       @default(now())

  @@unique([employeeId, month])
}

// Leave/Vacation Requests
model LeaveRequest {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  startDate       String         // YYYY-MM-DD
  endDate         String         // YYYY-MM-DD
  reason          String
  type            String         @default("عادية") // عادية, مرضية, طارئة, أخرى
  status          String         @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNotes      String?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
}

// Salary Change Log
model SalaryChangeLog {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  oldSalary       Float
  newSalary       Float
  reason          String?
  changedAt       DateTime       @default(now())
}

model FinancialRequest {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  amount          Float
  notes           String?
  status          String         @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNotes      String?
  createdAt       DateTime       @default(now())
}
